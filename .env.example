# API
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://execution:execution@localhost:5432/execution_os?schema=public
RABBITMQ_URL=amqp://guest:guest@localhost:5672
WHATSAPP_WEBHOOK_SECRET=
DEFAULT_PHONE_NUMBER=5511999999999
WHATSAPP_AUTO_DISPATCH_ENABLED=true
WHATSAPP_TIMEZONE=America/Sao_Paulo
WHATSAPP_MORNING_TIME=08:00
WHATSAPP_ACTIVE_WINDOW_START=08:00
WHATSAPP_ACTIVE_WINDOW_END=21:00
WHATSAPP_UPCOMING_EVERY_MINUTES=20
WHATSAPP_UPCOMING_WITHIN_MINUTES=20
NOTES_TRANSCRIBE_WEBHOOK_URL=
NOTES_TRANSCRIBE_WEBHOOK_SECRET=
NOTES_TRANSCRIBE_TIMEOUT_MS=45000

# Worker
WORKER_POLLING_INTERVAL_MS=15000
FOLLOWUP_REMINDER_DELAY_MINUTES=15
WHATSAPP_TRANSPORT=n8n
WHATSAPP_OUTBOUND_WEBHOOK_URL=http://localhost:5678/webhook/execution-os-outbound
WHATSAPP_OUTBOUND_WEBHOOK_SECRET=
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me

# Web
VITE_API_URL=http://localhost:3000
