DOMAIN=pluris.yrdnegocios.com.br

# App
DEFAULT_PHONE_NUMBER=5547999999999

# WhatsApp transport (n8n gateway)
WHATSAPP_TRANSPORT=n8n
WHATSAPP_OUTBOUND_WEBHOOK_URL=https://webhooks.yrdnegocios.com.br/webhook/execution-os-outbound
WHATSAPP_OUTBOUND_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_AUTO_DISPATCH_ENABLED=true
WHATSAPP_TIMEZONE=America/Sao_Paulo
WHATSAPP_MORNING_TIME=08:00
WHATSAPP_ACTIVE_WINDOW_START=08:00
WHATSAPP_ACTIVE_WINDOW_END=21:00
WHATSAPP_UPCOMING_EVERY_MINUTES=20
WHATSAPP_UPCOMING_WITHIN_MINUTES=20
FOLLOWUP_REMINDER_DELAY_MINUTES=15
NOTES_TRANSCRIBE_WEBHOOK_URL=
NOTES_TRANSCRIBE_WEBHOOK_SECRET=
NOTES_TRANSCRIBE_TIMEOUT_MS=45000

# Evolution fallback (only if WHATSAPP_TRANSPORT=evolution)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# Database / RabbitMQ
POSTGRES_USER=execution
POSTGRES_PASSWORD=execution
POSTGRES_DB=execution_os
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
